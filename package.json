{
  "name": "app",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.25.10"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --minify --tree-shaking=true --target=es2020",
    "build:dev": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --minify --tree-shaking=true --target=es2020",
    "build:css": "npx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.18",
    "@metamorfosilab/cookies-consent": "^0.2.9",
    "@rails/activestorage": "^8.1.300",
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.23.5",
    "@tiptap/extension-bubble-menu": "^3.23.5",
    "@tiptap/extension-image": "^3.23.5",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/extension-table": "^3.23.5",
    "@tiptap/extension-table-cell": "^3.23.5",
    "@tiptap/extension-table-header": "^3.23.5",
    "@tiptap/extension-table-row": "^3.23.5",
    "@tiptap/extension-underline": "^3.23.5",
    "@tiptap/extensions": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "altcha": "^2.2.4",
    "tailwindcss": "^4.1.14"
  }
}
