<%= form_with(model: [:admin, @user], class: "space-y-6") do |form| %>
  <% if @user.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:
      </h3>
      <ul class="list-disc list-inside text-sm text-red-700">
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :first_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :first_name, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :last_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :last_name, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.email_field :email, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      <% if @user.persisted? %>
        <p class="text-sm text-gray-500 mt-1">Leave blank to keep current</p>
      <% end %>
    </div>

    <div>
      <%= form.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    </div>
  </div>

  <div class="border-t border-gray-200 pt-6">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Author Profile</h2>

    <div class="space-y-6">
      <div>
        <%= form.label :job_title, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :job_title, placeholder: "e.g. Content Marketing Manager", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :bio, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_area :bio, rows: 4, placeholder: "A short bio that appears on published posts...", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :linkedin_url, "LinkedIn URL", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.url_field :linkedin_url, placeholder: "https://linkedin.com/in/...", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :twitter_handle, "Twitter Handle", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :twitter_handle, placeholder: "@handle (without the @)", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :avatar, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.file_field :avatar, accept: "image/*", aria: { label: "Upload avatar image" }, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
        <% if @user.persisted? && @user.avatar.attached? %>
          <div class="mt-2">
            <%= image_tag @user.avatar, class: "w-20 h-20 rounded-full object-cover" %>
          </div>
        <% end %>
        <p class="text-sm text-gray-500 mt-1">Shown on published blog posts. Square image recommended.</p>
      </div>

      <div class="flex items-center">
        <%= form.check_box :admin, class: "h-5 w-5 text-pink-600 focus:ring-pink-500 border-gray-300 rounded" %>
        <span class="ml-2 text-sm text-gray-600">This user has admin access</span>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
    <%= link_to "Cancel", admin_users_path, class: "px-6 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition font-medium" %>
    <%= form.submit @user.persisted? ? "Update User" : "Save User", class: "px-6 py-2 bg-pink-600 text-white rounded-md hover:bg-pink-700 transition font-medium cursor-pointer" %>
  </div>
<% end %>
