<%= form_with(model: [:admin, @blog], class: "space-y-6") do |form| %>
  <% if @blog.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(@blog.errors.count, "error") %> prohibited this blog from being saved:
      </h3>
      <ul class="list-disc list-inside text-sm text-red-700">
        <% @blog.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="md:col-span-2">
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :author, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :author, value: @blog[:author], class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :author_id, "Author Profile", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.collection_select :author_id,
            User.order(:first_name),
            :id,
            :full_name,
            { include_blank: "— No author profile —", selected: @blog.author_id },
            class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      <p class="text-sm text-gray-500 mt-1">Overrides the Author text field when set. Select an admin user to show their full profile card on the published post.</p>
    </div>

    <div>
      <%= form.label :category, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :category, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent", placeholder: "e.g., Sales Strategy" %>
    </div>

    <div>
      <%= form.label :spacing, "Paragraph Spacing", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :spacing,
            [["Normal", "normal"], ["Relaxed", "relaxed"]],
            { selected: @blog.spacing || "normal" },
            class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      <p class="text-sm text-gray-500 mt-1">Relaxed adds more space between paragraphs</p>
    </div>

    <div>
      <%= form.label :published_at, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.datetime_field :published_at, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      <p class="text-sm text-gray-500 mt-1">Leave blank for draft</p>
    </div>

    <div>
      <%= form.label :meta_title, "SEO Title", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :meta_title, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      <p class="text-sm text-gray-500 mt-1">Leave blank to use title ("<%= @blog.title.presence || '...' %> - Revnous")</p>
    </div>

    <div>
      <%= form.label :meta_description, "SEO Description", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :meta_description, rows: 2, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      <p class="text-sm text-gray-500 mt-1">Leave blank to use first paragraph of content</p>
    </div>

    <div>
      <%= form.label :slug, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :slug, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent", placeholder: "auto-generated if blank" %>
      <p class="text-sm text-gray-500 mt-1">URL-friendly version of title</p>
    </div>

    <div>
      <%= form.label :canonical_url_override, "Canonical URL Override", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :canonical_url_override, placeholder: "https://example.com/blog/your-post", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
      <p class="text-sm text-gray-500 mt-1">Overrides the auto-generated canonical URL. Leave blank to use the default post URL.</p>
    </div>

    <div class="md:col-span-2">
      <label class="block text-sm font-medium text-gray-700 mb-2">Keywords</label>
      <div data-controller="keywords-input" role="group" aria-label="Keywords">
        <div data-keywords-input-target="chipContainer" class="flex flex-wrap items-center gap-2 w-full px-3 py-2 border border-gray-300 rounded-md focus-within:ring-2 focus-within:ring-pink-500 focus-within:border-transparent min-h-[42px]">
          <% Array(@blog.keywords).each_with_index do |kw, i| %>
            <input type="hidden" name="blog[keywords][]" value="<%= kw %>">
            <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-semibold bg-pink-50 text-pink-700 border border-pink-200">
              <span><%= kw %></span>
              <button type="button"
                      data-action="click->keywords-input#removeChip"
                      data-index="<%= i %>"
                      aria-label="Remove <%= kw %>"
                      class="h-4 w-4 inline-flex items-center justify-center rounded-full hover:bg-pink-200">×</button>
            </span>
          <% end %>
          <input type="text"
                 data-keywords-input-target="input"
                 data-action="keydown->keywords-input#addChip"
                 class="flex-1 min-w-[120px] px-2 py-1 text-sm outline-none bg-transparent"
                 placeholder="Type a keyword and press Enter...">
        </div>
      </div>
      <p class="text-sm text-gray-500 mt-1">Press Enter or comma to add. Click &times; to remove. Used in &lt;meta name=&quot;keywords&quot;&gt; when published.</p>
    </div>

    <div class="md:col-span-2">
      <%= form.label :featured, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.check_box :featured, class: "h-5 w-5 text-pink-600 focus:ring-pink-500 border-gray-300 rounded" %>
      <span class="ml-2 text-sm text-gray-600">Feature this post on blog homepage</span>
    </div>

    <div class="md:col-span-2">
      <%= form.label :featured_on_home, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.check_box :featured_on_home, class: "h-5 w-5 text-pink-600 focus:ring-pink-500 border-gray-300 rounded" %>
      <span class="ml-2 text-sm text-gray-600">Feature this post on main homepage</span>
    </div>

    <div class="md:col-span-2">
      <%= form.label :product_ids, "Associated Products", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.collection_check_boxes :product_ids, Product.ordered, :id, :name do |b| %>
        <div class="flex items-center mb-2">
          <%= b.check_box class: "h-4 w-4 text-pink-600 focus:ring-pink-500 border-gray-300 rounded" %>
          <%= b.label class: "ml-2 text-sm text-gray-600" %>
        </div>
      <% end %>
      <p class="text-sm text-gray-500 mt-1">Select products this blog is related to</p>
    </div>
  </div>

  <div>
    <%= form.label :excerpt, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :excerpt, rows: 3, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent", placeholder: "A short summary that appears in listings..." %>
  </div>

  <div>
    <%= form.label :body, "Content", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <div class="tiptap-editor" data-controller="tiptap-editor">
      <div class="tiptap-toolbar sticky top-0 z-10 bg-white border border-gray-300 rounded-t-md px-3 py-2 flex items-center gap-1 flex-wrap" role="toolbar" aria-label="Editor toolbar">
        <%# History group: Undo / Redo %>
        <button type="button"
                data-action="click->tiptap-editor#undo"
                title="Undo"
                aria-label="Undo"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 7v6h6"/><path d="M3 13C5.33 7.67 9.33 5 13 5c3.67 0 7 2 9 6"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#redo"
                title="Redo"
                aria-label="Redo"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 7v6h-6"/><path d="M21 13C18.67 7.67 14.67 5 11 5c-3.67 0-7 2-9 6"/>
          </svg>
        </button>

        <div class="w-px h-6 bg-gray-200 mx-1" role="separator" aria-hidden="true"></div>

        <%# Heading group: H1–H6 %>
        <% [1, 2, 3, 4, 5, 6].each do |level| %>
          <button type="button"
                  data-action="click->tiptap-editor#setHeading"
                  data-tiptap-editor-level-param="<%= level %>"
                  data-tiptap-state="heading:<%= level %>"
                  aria-pressed="false"
                  title="Heading <%= level %>"
                  class="inline-flex items-center justify-center h-9 px-2 text-xs font-semibold rounded text-gray-700 hover:bg-gray-100 transition-colors">
            H<%= level %>
          </button>
        <% end %>

        <div class="w-px h-6 bg-gray-200 mx-1" role="separator" aria-hidden="true"></div>

        <%# Inline format group: Bold / Italic / Underline / Strike %>
        <button type="button"
                data-action="click->tiptap-editor#toggleBold"
                data-tiptap-state="bold"
                aria-pressed="false"
                title="Bold"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#toggleItalic"
                data-tiptap-state="italic"
                aria-pressed="false"
                title="Italic"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#toggleUnderline"
                data-tiptap-state="underline"
                aria-pressed="false"
                title="Underline"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" y1="20" x2="20" y2="20"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#toggleStrike"
                data-tiptap-state="strike"
                aria-pressed="false"
                title="Strikethrough"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><path d="M16 6C16 6 14.5 4 12 4s-4.5 1.5-4.5 3.5c0 2 1.5 3 3 3.5"/>
            <path d="M8 18c0 0 1.5 2 4 2s4.5-1.5 4.5-3.5"/>
          </svg>
        </button>

        <div class="w-px h-6 bg-gray-200 mx-1" role="separator" aria-hidden="true"></div>

        <%# Code group: inline code / code block %>
        <button type="button"
                data-action="click->tiptap-editor#toggleCode"
                data-tiptap-state="code"
                aria-pressed="false"
                title="Inline code"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#toggleCodeBlock"
                data-tiptap-state="codeBlock"
                aria-pressed="false"
                title="Code block"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><path d="m10 10-2 2 2 2"/><path d="m14 10 2 2-2 2"/>
          </svg>
        </button>

        <div class="w-px h-6 bg-gray-200 mx-1" role="separator" aria-hidden="true"></div>

        <%# Block group: Blockquote / Horizontal Rule %>
        <button type="button"
                data-action="click->tiptap-editor#toggleBlockquote"
                data-tiptap-state="blockquote"
                aria-pressed="false"
                title="Blockquote"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 2v7c0 1.25.757 2.017 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/>
            <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 2v7c0 1.25.757 2.017 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#setHorizontalRule"
                title="Horizontal rule"
                aria-label="Horizontal rule"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"/>
          </svg>
        </button>

        <div class="w-px h-6 bg-gray-200 mx-1" role="separator" aria-hidden="true"></div>

        <%# List group: Bullet / Ordered %>
        <button type="button"
                data-action="click->tiptap-editor#toggleBulletList"
                data-tiptap-state="bulletList"
                aria-pressed="false"
                title="Bullet list"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/>
            <circle cx="4" cy="6" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#toggleOrderedList"
                data-tiptap-state="orderedList"
                aria-pressed="false"
                title="Numbered list"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/>
            <text x="1" y="9" font-size="7" fill="currentColor" stroke="none">1.</text><text x="1" y="15" font-size="7" fill="currentColor" stroke="none">2.</text><text x="1" y="21" font-size="7" fill="currentColor" stroke="none">3.</text>
          </svg>
        </button>

        <div class="w-px h-6 bg-gray-200 mx-1" role="separator" aria-hidden="true"></div>

        <%# Link group %>
        <button type="button"
                data-action="click->tiptap-editor#setLink"
                data-tiptap-state="link"
                aria-pressed="false"
                title="Insert link"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
        </button>

        <div class="w-px h-6 bg-gray-200 mx-1" role="separator" aria-hidden="true"></div>

        <%# Media group: Table / Image %>
        <button type="button"
                data-action="click->tiptap-editor#insertTable"
                data-tiptap-state="table"
                title="Insert table"
                aria-label="Insert table"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/><path d="M15 3v18"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#triggerImageUpload"
                title="Upload image"
                aria-label="Upload image"
                class="inline-flex items-center justify-center h-9 w-9 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
          </svg>
        </button>
      </div>
      <div class="tiptap-bubble-menu bg-white border border-gray-200 rounded-md shadow-lg px-2 py-1 flex items-center gap-1"
           data-tiptap-editor-target="tableMenu"
           role="toolbar"
           aria-label="Table controls"
           hidden>
        <button type="button"
                data-action="click->tiptap-editor#addRowBefore"
                title="Add row above"
                aria-label="Add row above"
                class="inline-flex items-center justify-center h-8 w-8 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h18"/><path d="M3 12h18"/><path d="M9 3v6"/><path d="M12 3v1"/><line x1="12" y1="2" x2="12" y2="6"/>
            <path d="M8 5l4-4 4 4"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#addRowAfter"
                title="Add row below"
                aria-label="Add row below"
                class="inline-flex items-center justify-center h-8 w-8 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h18"/><path d="M3 12h18"/>
            <path d="M8 19l4 4 4-4"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#deleteRow"
                title="Remove row"
                aria-label="Remove row"
                class="inline-flex items-center justify-center h-8 w-8 rounded text-gray-700 hover:bg-gray-100 hover:bg-red-50 hover:text-red-600 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 10h18"/><path d="M3 14h18"/>
            <line x1="4" y1="12" x2="20" y2="12" stroke-dasharray="4 2"/>
            <line x1="18" y1="9" x2="22" y2="13"/><line x1="22" y1="9" x2="18" y2="13"/>
          </svg>
        </button>
        <div class="w-px h-5 bg-gray-200 mx-0.5" role="separator" aria-hidden="true"></div>
        <button type="button"
                data-action="click->tiptap-editor#addColumnBefore"
                title="Add column left"
                aria-label="Add column left"
                class="inline-flex items-center justify-center h-8 w-8 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 3v18"/><path d="M13 3v18"/>
            <path d="M5 8l-4 4 4 4"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#addColumnAfter"
                title="Add column right"
                aria-label="Add column right"
                class="inline-flex items-center justify-center h-8 w-8 rounded text-gray-700 hover:bg-gray-100 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 3v18"/><path d="M15 3v18"/>
            <path d="M19 8l4 4-4 4"/>
          </svg>
        </button>
        <button type="button"
                data-action="click->tiptap-editor#deleteColumn"
                title="Remove column"
                aria-label="Remove column"
                class="inline-flex items-center justify-center h-8 w-8 rounded text-gray-700 hover:bg-gray-100 hover:bg-red-50 hover:text-red-600 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v18"/>
            <line x1="9" y1="18" x2="13" y2="22"/><line x1="13" y1="18" x2="9" y2="22"/>
          </svg>
        </button>
        <div class="w-px h-5 bg-gray-200 mx-0.5" role="separator" aria-hidden="true"></div>
        <button type="button"
                data-action="click->tiptap-editor#deleteTable"
                title="Delete table"
                aria-label="Delete table"
                class="inline-flex items-center justify-center h-8 w-8 rounded text-red-600 hover:bg-red-50 transition-colors">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/>
          </svg>
        </button>
      </div>
      <input type="file"
             accept="image/*"
             data-tiptap-editor-target="imageFileInput"
             data-action="change->tiptap-editor#handleImageFileSelected"
             class="hidden">
      <div class="border border-t-0 border-gray-300 rounded-b-md focus-within:ring-2 focus-within:ring-pink-500"
           data-tiptap-editor-target="editor"
           role="textbox"
           aria-multiline="true"
           aria-label="Blog content"></div>
      <%= form.hidden_field :body, data: { tiptap_editor_target: "input" } %>
    </div>
    <p class="text-sm text-gray-500 mt-1">Supports rich text and heading formatting</p>
  </div>

  <div>
    <%= form.label :og_image, "OG Image (Social Share)", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.file_field :og_image, accept: "image/*", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    <% if @blog.persisted? && @blog.og_image.attached? %>
      <div class="mt-2">
        <%= image_tag @blog.og_image, class: "h-32 w-auto rounded" %>
      </div>
    <% end %>
    <p class="text-sm text-gray-500 mt-1">Overrides cover photo for social sharing. Falls back to cover photo, then site logo when absent.</p>
  </div>

  <div>
    <%= form.label :image, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.file_field :image, accept: "image/*", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent" %>
    <% if @blog.persisted? && @blog.image.attached? %>
      <div class="mt-2">
        <%= image_tag @blog.image, class: "h-32 w-auto rounded" %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
    <%= link_to "Cancel", admin_blogs_path, class: "px-6 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition font-medium" %>
    <%= form.submit class: "px-6 py-2 bg-pink-600 text-white rounded-md hover:bg-pink-700 transition font-medium cursor-pointer" %>
  </div>
<% end %>
