<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Invite Admin</h1>
  <p class="text-gray-600 mt-2">Send an invitation to a new admin user</p>
</div>

<div class="bg-white rounded-lg shadow p-8 max-w-lg">
  <%= form_with(url: admin_invitations_path, scope: :admin_invitation, class: "space-y-6") do |form| %>
    <% if @invitation.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 p-4">
        <ul class="list-disc list-inside text-sm text-red-700">
          <% @invitation.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.email_field :email, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-pink-500 focus:border-transparent", placeholder: "admin@example.com", autofocus: true %>
      <p class="text-sm text-gray-500 mt-1">The invitation link expires in 72 hours.</p>
    </div>

    <div class="flex items-center justify-end space-x-4 pt-4 border-t border-gray-200">
      <%= link_to "Cancel", admin_invitations_path, class: "px-6 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition font-medium" %>
      <%= form.submit "Send Invitation", class: "px-6 py-2 bg-pink-600 text-white rounded-md hover:bg-pink-700 transition font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>
