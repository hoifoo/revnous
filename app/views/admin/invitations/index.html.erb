<div class="flex justify-between items-center mb-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Admin Invitations</h1>
    <p class="text-gray-600 mt-2">Manage pending and past invitations</p>
  </div>
  <%= link_to new_admin_invitation_path, class: "px-6 py-3 bg-pink-600 text-white rounded-md hover:bg-pink-700 transition font-medium inline-flex items-center" do %>
    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Invite Admin
  <% end %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Invited By</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sent</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Expires</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @invitations.each do |invitation| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= invitation.email %></td>
          <td class="px-6 py-4 text-sm text-gray-600">
            <%= invitation.invited_by.first_name.presence || invitation.invited_by.email %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= invitation.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= invitation.expires_at.strftime("%b %d, %Y %H:%M") %></td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% badge_class = case invitation.status
               when "accepted" then "bg-green-100 text-green-800"
               when "rejected" then "bg-red-100 text-red-800"
               else invitation.expired? ? "bg-gray-100 text-gray-600" : "bg-yellow-100 text-yellow-800"
               end %>
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= badge_class %>">
              <%= invitation.status == "pending" && invitation.expired? ? "expired" : invitation.status.capitalize %>
            </span>
          </td>
        </tr>
      <% end %>
      <% if @invitations.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-8 text-center text-gray-500">No invitations yet.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
