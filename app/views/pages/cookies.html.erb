<% content_for :title, "Cookie Policy - Revnous" %>
<% content_for :meta_description, "What cookies and analytics tools Revnous uses, why, and how to manage your preferences." %>

<%= render "shared/notice_banner" %>

<!-- Cookies Section -->
<div class="bg-white py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <div class="mb-6">
      <%= link_to root_path, class: "text-pink-600 hover:text-pink-700 font-medium text-sm" do %>
        ← Back to Home
      <% end %>
    </div>

    <!-- Title -->
    <h1 class="text-5xl font-bold text-gray-900 mb-8">Cookie Policy</h1>

    <div class="prose prose-lg max-w-none mb-10 text-gray-800">
      <p class="mb-4">
        This page lists every analytics tool Revnous uses, what it tracks, and why. We do not sell
        your data; analytics data is used only for product and UX development. You can change your
        preferences at any time.
      </p>

      <button type="button"
              class="inline-block px-6 py-3 bg-pink-600 text-white rounded-md hover:bg-pink-700 transition font-medium cursor-pointer"
              onclick="window.__cookieConsentInstance && window.__cookieConsentInstance.toggleSettings();">
        Manage Cookie Settings
      </button>
    </div>

    <% providers = enabled_analytics_providers %>

    <% if providers.any? %>
      <div class="overflow-x-auto mb-10">
        <table class="min-w-full border border-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">Tool</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">Purpose</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">Cookies</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">Processor</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">Transfer basis</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">Policy</th>
            </tr>
          </thead>
          <tbody>
            <% providers.each do |provider| %>
              <tr class="border-b border-gray-100">
                <td class="px-4 py-3 font-medium text-gray-900"><%= provider["name"] %></td>
                <td class="px-4 py-3 text-gray-700">
                  <span class="px-2 py-0.5 bg-pink-100 text-pink-700 text-xs font-semibold rounded-full uppercase tracking-wide mr-2">
                    <%= provider["category"] %>
                  </span>
                  <%= provider["description"] %>
                </td>
                <td class="px-4 py-3 text-gray-700">
                  <ul class="space-y-1">
                    <% Array(provider["cookies"]).each do |cookie| %>
                      <li><code class="text-xs"><%= cookie["name"] %></code> &mdash; <%= cookie["purpose"] %> (<%= cookie["retention"] %>)</li>
                    <% end %>
                  </ul>
                </td>
                <td class="px-4 py-3 text-gray-700"><%= provider.dig("privacy", "processor") %></td>
                <td class="px-4 py-3 text-gray-700"><%= provider.dig("privacy", "transfer") %></td>
                <td class="px-4 py-3">
                  <% policy_url = provider.dig("privacy", "policy_url") %>
                  <% if policy_url.present? %>
                    <%= link_to "Privacy Policy", policy_url, target: "_blank", rel: "noopener", class: "text-pink-600 hover:text-pink-700 underline" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="mb-10 text-gray-700">No analytics tools are currently active.</p>
    <% end %>

    <!-- More Info CTA -->
    <div class="border-t border-gray-200 pt-8">
      <div class="bg-gray-50 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">More information</h3>
        <p class="text-gray-600 mb-4">
          For details on how we handle personal data, see our
          <%= link_to "Privacy Policy", privacy_policy_path, class: "text-pink-600 hover:text-pink-700 underline" %>
          or our
          <%= link_to "Impressum", impressum_path, class: "text-pink-600 hover:text-pink-700 underline" %>.
        </p>
        <%= link_to "Contact Us", contact_us_path, class: "inline-block px-6 py-3 bg-pink-600 text-white rounded-md hover:bg-pink-700 transition font-medium" %>
      </div>
    </div>
  </div>
</div>
